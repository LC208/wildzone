DEBUG=True
SECRET_KEY=changeme-replace-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS — при DEBUG=True и без этой переменной разрешаются все origins.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

PARSING_REQUEST_DELAY=1.5

# Путь к директории проекта на хосте (нужен backend-контейнеру для Selenium).
HOST_PROJECT_PATH=/path/to/wildzone

# Email (только для production, в DEBUG письма выводятся в консоль)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=your@gmail.com
